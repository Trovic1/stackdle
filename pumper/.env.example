# ============================================
# Stackdle Transaction Pumper Configuration
# ============================================

# Your Stacks wallet private key (64-char hex string)
# WARNING: Never commit this file with real keys!
PRIVATE_KEY=your_stacks_private_key_here

# Network: 'testnet' or 'mainnet'
NETWORK=testnet

# Contract deployer address (your STX address)
CONTRACT_ADDRESS=ST_YOUR_ADDRESS_HERE

# Contract name
CONTRACT_NAME=stackdle

# Current game ID to enter
GAME_ID=1

# Number of transactions to send
TX_COUNT=50

# Delay between transactions in milliseconds
TX_DELAY_MS=2000
